# markt server — Environment Variables
# Copy this file to .env and fill in real values.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, good for single-machine deploys):
DATABASE_URL=marktbot-server.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/marktbot?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_real_secret_at_least_32_chars

# ── AI (OpenAI-compatible) ────────────────────────────────────────────────────
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1   # default; change for Claude, local LLMs, etc.

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Leave blank to disable billing; the server still runs in free-tier-only mode.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard (Products → Pricing):
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
SERVER_ADDR=:8000
APP_BASE_URL=http://localhost:3000   # Used for Stripe redirect URLs

# -- Deal Alert Email (optional) ------------------------------------------------
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=alerts@yourapp.com
SMTP_PASS=yourpassword
SMTP_FROM=alerts@markt.app
ALERT_SCORE=8.0
