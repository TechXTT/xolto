# xolto server — Environment Variables
# Copy this file to .env and fill in real values.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, good for single-machine deploys):
DATABASE_URL=xolto-server.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/xolto?sslmode=disable
# DB pool tuning (defaults shown):
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=30m

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_real_secret_at_least_32_chars

# ── AI (OpenAI-compatible) ────────────────────────────────────────────────────
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
# Bump to invalidate cached AI scores.
# AI_PROMPT_VERSION=1
# AI_BASE_URL=https://api.openai.com/v1   # default; change for Claude, local LLMs, etc.

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Leave blank to disable billing; the server still runs in free-tier-only mode.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard (Products → Pricing):
STRIPE_PRO_PRICE_ID=price_...
STRIPE_POWER_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
SERVER_ADDR=:8000
# APP_ENV=development # set to production for JSON logs
# Optional HTTP server timeout overrides.
# SERVER_READ_TIMEOUT=15s
# SERVER_WRITE_TIMEOUT=30s
# SERVER_IDLE_TIMEOUT=60s
# SERVER_READ_HEADER_TIMEOUT=5s
APP_BASE_URL=http://localhost:3000   # Used for Stripe redirect URLs
ADMIN_BASE_URL=http://localhost:3002 # xolto-admin URL
# Preferred CORS origins (comma-separated). Include all frontend origins.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Legacy fallback (deprecated; will be removed after rollout):
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Admin Security ────────────────────────────────────────────────────────────
# Set to true only when requests pass through a trusted reverse proxy.
# TRUST_PROXY=false
# Optional comma-separated CIDRs/IPs. Empty means no IP filter.
# ADMIN_IP_ALLOWLIST=203.0.113.0/24,198.51.100.14
# Optional comma-separated allowlist of bootstrap admin emails.
# ADMIN_EMAILS=admin@xolto.app,ops@xolto.app

# -- Deal Alert Email (optional) ------------------------------------------------
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=alerts@yourapp.com
SMTP_PASS=yourpassword
SMTP_FROM=alerts@xolto.app
ALERT_SCORE=8.0
